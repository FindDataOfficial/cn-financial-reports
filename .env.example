# cnreport-mcp overrides only. Root .env is loaded first (see server.py).
# LLM credentials are shared with the rest of the repo (LLM_BASE_URL /
# LLM_API_KEY / LLM_MODEL) — set those in the root .env.

# ── Elasticsearch ───────────────────────────────────────────────
ES_URL=http://localhost:9200
# Prefer API key; fall back to basic auth if API key unset.
#ES_API_KEY=
#ES_USERNAME=
#ES_PASSWORD=

# ── Fetcher ─────────────────────────────────────────────────────
# v1 uses httpx/pypdf directly; reserved for future scrapling wiring.
CNREPORT_FETCHER=uv

# ── Report cache ────────────────────────────────────────────────
# Downloaded annual reports (PDF + extracted text + outline) are cached here
# so repeated section extractions don't re-download. Defaults to
# mcp/cnreport-mcp/.cache/reports/ when unset.
#CNREPORT_CACHE_DIR=
